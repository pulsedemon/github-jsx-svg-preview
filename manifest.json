{
  "manifest_version": 3,
  "name": "GitHub JSX SVG Preview",
  "version": "1.0.0",
  "description": "Preview SVG icons embedded in JSX/TSX files directly on GitHub pull requests.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": [
        "lib/jsx-to-svg.js",
        "lib/svg-extractor.js",
        "lib/preview-renderer.js",
        "content.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
